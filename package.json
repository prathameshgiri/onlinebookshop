{
  "name": "online-book-shop",
  "version": "1.0.0",
  "description": "A full-stack online book shop with user and admin portals",
  "scripts": {
    "start": "npm install && npm run seed && npm run dev",
    "dev": "concurrently \"npm run user\" \"npm run admin\"",
    "user": "node server/user-server.js",
    "admin": "node server/admin-server.js",
    "seed": "node server/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lowdb": "^1.0.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
